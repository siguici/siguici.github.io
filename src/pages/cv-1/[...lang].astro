---
import AppLayout from '../../layouts/AppLayout.astro';
import getCV, { type Locale } from '../../data/cv';

interface Props {
  lang: Locale;
}

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: 'fr' } },
    { params: { lang: 'fr' }, props: { lang: 'fr' } },
    { params: { lang: 'en' }, props: { lang: 'en' } },
  ];
}

const { lang } = Astro.props as { lang: Locale };
const cv = getCV(lang);
---

<AppLayout
  title={cv.title}
  cssClass="bg-[#080B11] text-slate-300 antialiased selection:bg-cyan-500 selection:text-black font-sans transition-colors duration-300"
>
  <!-- SEO & Open Graph Meta Tags -->
  <meta name="description" content={cv.tagline} />
  <meta name="author" content={cv.identity.name} />

  <meta property="og:title" content={cv.title} />
  <meta property="og:description" content={cv.tagline} />
  <meta property="og:type" content="profile" />

  <!-- Fonts & Web Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Geist:wght@100..900&display=swap" rel="stylesheet">

  <!-- Structured Data (JSON-LD) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": cv.identity.name,
    "jobTitle": cv.subtitle,
    "url": cv.contact.webUrl,
    "sameAs": [
      cv.contact.githubUrl,
      cv.contact.linkedinUrl
    ]
  })} />

  <!-- ACTION BAR (HIDDEN IN PRINT) -->
  <nav class="actions-bar max-w-5xl mx-auto px-4 pt-6 pb-2 flex justify-between items-center print:hidden">
    <a href="/" class="text-xs font-mono text-slate-400 hover:text-cyan-400 transition-colors flex items-center gap-1">
      {lang === 'fr' ? '← RETOUR AU SITE' : '← BACK TO WEBSITE'}
    </a>

    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2 bg-slate-900/80 border border-white/10 px-3 py-1.5 rounded-full text-xs font-mono">
        <a
          href="/cv/fr"
          class:list={['transition-colors', lang === 'fr' ? 'text-cyan-400 font-bold' : 'text-slate-500 hover:text-slate-300']}
        >
          FR
        </a>
        <span class="text-slate-700">|</span>
        <a
          href="/cv/en"
          class:list={['transition-colors', lang === 'en' ? 'text-cyan-400 font-bold' : 'text-slate-500 hover:text-slate-300']}
        >
          EN
        </a>
      </div>

      <button onclick="window.print()" class="bg-cyan-500/10 border border-cyan-500/30 hover:bg-cyan-500/20 text-cyan-300 font-mono text-xs px-4 py-1.5 rounded-full font-semibold transition-all shadow-[0_0_15px_rgba(6,182,212,0.15)] hover:shadow-[0_0_20px_rgba(6,182,212,0.3)]">
        {lang === 'fr' ? 'EXPORTER / IMPRIMER PDF' : 'DOWNLOAD PDF / PRINT'}
      </button>
    </div>
  </nav>

  <!-- MAIN BENTO CONTAINER -->
  <main class="max-w-5xl mx-auto p-4 md:p-8 space-y-6 bg-grid">

    <!-- HERO HEADER CARD -->
    <header class="bento-card relative overflow-hidden rounded-3xl border border-white/10 bg-slate-900/60 p-6 md:p-8 backdrop-blur-xl">
      <!-- Ambient Glow Effects -->
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-violet-500/10 rounded-full blur-3xl pointer-events-none"></div>

      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 relative z-10">
        <div class="space-y-3">
          <!-- Status Tag -->
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-emerald-500/30 bg-emerald-500/10 text-emerald-400 font-mono text-xs">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            <span>{cv.location}</span>
          </div>

          <!-- Identity & Title -->
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-black tracking-tight text-white">
            {cv.identity.name}
          </h1>
          <p class="font-mono text-xs sm:text-sm text-cyan-400 font-semibold tracking-wide uppercase">
            // {cv.subtitle}
          </p>
        </div>

        <!-- Spec Metric Badge -->
        <div class="border border-white/10 bg-white/[0.02] p-4 rounded-2xl font-mono text-xs space-y-1 w-full md:w-auto">
          <span class="text-slate-500 block text-[10px] uppercase tracking-wider">// SYSTEM SPECS</span>
          <p class="text-slate-200 font-bold">10+ YEARS EXP.</p>
          <p class="text-violet-400">VLANG / PHP ARCH</p>
        </div>
      </div>

      <!-- Tagline Statement -->
      <blockquote class="mt-6 pt-4 border-t border-white/10 text-xs sm:text-sm text-slate-300 italic font-sans leading-relaxed">
        "{cv.tagline}"
      </blockquote>

      <!-- Dynamic Contact Bar -->
      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-2 font-mono text-xs bg-black/40 p-3 rounded-xl border border-white/5 text-slate-400">
        <div>
          <span class="text-slate-600 block text-[10px]">EMAIL</span>
          <a href={`mailto:${cv.contact.email}`} class="hover:text-cyan-400 transition-colors truncate block">{cv.contact.email}</a>
        </div>
        <div>
          <span class="text-slate-600 block text-[10px]">WEB</span>
          <a href={cv.contact.webUrl} target="_blank" class="hover:text-cyan-400 transition-colors truncate block">{cv.contact.web}</a>
        </div>
        <div>
          <span class="text-slate-600 block text-[10px]">GITHUB</span>
          <a href={cv.contact.githubUrl} target="_blank" class="hover:text-cyan-400 transition-colors truncate block">{cv.contact.github}</a>
        </div>
        <div>
          <span class="text-slate-600 block text-[10px]">LINKEDIN</span>
          <a href={cv.contact.linkedinUrl} target="_blank" class="hover:text-cyan-400 transition-colors truncate block">{cv.contact.linkedin}</a>
        </div>
      </div>
    </header>

    <!-- EXECUTIVE PROFILE / SUMMARY -->
    <section class="bento-card rounded-3xl border border-white/10 bg-slate-900/40 p-6 md:p-8 backdrop-blur-xl">
      <div class="flex items-center justify-between border-b border-white/10 pb-3 mb-4">
        <h2 class="font-mono text-xs uppercase tracking-widest text-cyan-400 font-bold flex items-center gap-2">
          <span class="text-slate-600">//</span> {cv.sections.profile}
        </h2>
        <span class="font-mono text-xs text-slate-600">01.OVERVIEW</span>
      </div>
      <div class="text-xs sm:text-sm text-slate-300 leading-relaxed font-sans" set:html={cv.summary} />
    </section>

    <!-- CORE CAPABILITIES GRID -->
    <section class="bento-card rounded-3xl border border-white/10 bg-slate-900/40 p-6 md:p-8 backdrop-blur-xl space-y-4">
      <div class="flex items-center justify-between border-b border-white/10 pb-3">
        <h2 class="font-mono text-xs uppercase tracking-widest text-violet-400 font-bold flex items-center gap-2">
          <span class="text-slate-600">//</span> {cv.sections.capabilities}
        </h2>
        <span class="font-mono text-xs text-slate-600">02.CAPABILITIES</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {cv.capabilities.map((cap) => (
          <div class="p-4 rounded-2xl border border-white/5 bg-white/[0.015] hover:border-violet-500/30 transition-colors space-y-1">
            <h3 class="font-mono text-xs font-bold text-cyan-300">{cap.title}</h3>
            <p class="text-xs text-slate-400 leading-relaxed">{cap.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- PROFESSIONAL EXPERIENCES -->
    <section class="bento-card rounded-3xl border border-white/10 bg-slate-900/40 p-6 md:p-8 backdrop-blur-xl space-y-6">
      <div class="flex items-center justify-between border-b border-white/10 pb-3">
        <h2 class="font-mono text-xs uppercase tracking-widest text-cyan-400 font-bold flex items-center gap-2">
          <span class="text-slate-600">//</span> {cv.sections.experience}
        </h2>
        <span class="font-mono text-xs text-slate-600">03.EXPERIENCE</span>
      </div>

      <div class="space-y-6">
        {cv.experiences.map((exp) => (
          <div class="relative pl-5 border-l-2 border-white/10 hover:border-cyan-500/50 transition-colors space-y-2">
            <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-1">
              <h3 class="text-sm sm:text-base font-bold text-white">
                {exp.role} — <span class="text-cyan-400 font-mono text-xs sm:text-sm">{exp.company}</span>
              </h3>
              <span class="font-mono text-xs text-slate-500 font-semibold">{exp.period}</span>
            </div>
            {exp.subtitle && <p class="font-mono text-xs text-slate-400 italic">{exp.subtitle}</p>}
            <ul class="space-y-1.5 pt-1">
              {exp.impacts.map((impact) => (
                <li class="text-xs sm:text-sm text-slate-300 leading-relaxed flex items-start gap-2">
                  <span class="text-violet-400 font-mono mt-0.5">›</span>
                  <span set:html={impact} />
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- TWO-COL GRID: TECHNICAL ECOSYSTEM & EDUCATION -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

      <!-- ECOSYSTEM (7 COLS) -->
      <section class="md:col-span-7 bento-card rounded-3xl border border-white/10 bg-slate-900/40 p-6 md:p-8 backdrop-blur-xl space-y-4">
        <div class="flex items-center justify-between border-b border-white/10 pb-3">
          <h2 class="font-mono text-xs uppercase tracking-widest text-violet-400 font-bold flex items-center gap-2">
            <span class="text-slate-600">//</span> {cv.sections.ecosystem}
          </h2>
          <span class="font-mono text-xs text-slate-600">04.STACK</span>
        </div>

        <div class="space-y-4">
          {cv.ecosystem.map((group) => (
            <div class="space-y-1.5">
              <strong class="font-mono text-xs text-slate-200 block">
                {cv.categories[group.categoryId as keyof typeof cv.categories]}:
              </strong>
              <div class="flex flex-wrap gap-1.5">
                {group.skills.map((skill) => (
                  <span class="px-2.5 py-1 rounded-lg border border-white/10 bg-white/5 font-mono text-[11px] text-slate-300">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- EDUCATION & LANGUAGES (5 COLS) -->
      <aside class="md:col-span-5 bento-card rounded-3xl border border-white/10 bg-slate-900/40 p-6 md:p-8 backdrop-blur-xl space-y-6 flex flex-col justify-between">
        <div class="space-y-4">
          <div class="flex items-center justify-between border-b border-white/10 pb-3">
            <h2 class="font-mono text-xs uppercase tracking-widest text-cyan-400 font-bold flex items-center gap-2">
              <span class="text-slate-600">//</span> {cv.sections.education}
            </h2>
            <span class="font-mono text-xs text-slate-600">05.EDU</span>
          </div>

          <div class="space-y-4">
            {cv.education.map((edu) => (
              <div class="border-b border-white/5 pb-3 last:border-0 last:pb-0">
                <div class="text-xs font-bold text-white font-mono">{edu.degree}</div>
                {edu.institution && <div class="text-xs text-slate-400 mt-0.5">{edu.institution}</div>}
                <div class="font-mono text-[10px] text-slate-500 mt-1">{edu.period}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Languages Box -->
        <div class="pt-4 border-t border-white/10 font-mono text-xs">
          <span class="text-slate-500 uppercase block text-[10px]">{lang === 'fr' ? 'LANGUES' : 'LANGUAGES'}</span>
          <p class="text-cyan-300 font-semibold mt-1">{cv.languages}</p>
        </div>
      </aside>

    </div>

  </main>
</AppLayout>

<style>
  /* Applied Font System */
  :root {
    font-family: 'Geist', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  
  .font-mono {
    font-family: 'Geist Mono', monospace;
  }

  /* Subtle Dotted Background Pattern */
  .bg-grid {
    background-image: radial-gradient(rgba(255, 255, 255, 0.07) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  /* Deep HTML formatting inside set:html */
  :global(.bento-card strong) {
    color: #f8fafc !important;
    font-weight: 700;
  }

  /* =========================================================
     STRICT A4 PRINT STYLES WITH FULL DARK-MODE PRESERVATION
     ========================================================= */
  @media print {
    @page {
      size: A4 portrait;
      margin: 8mm;
    }

    /* Force the browser print engine to keep background colors & glows */
    html, body {
      background-color: #080b11 !important;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      color-adjust: exact !important;
      color: #cbd5e1 !important;
    }

    /* Hide Navigation Bar and page elements not meant for print */
    .actions-bar {
      display: none !important;
    }

    .bg-grid {
      background-image: none !important;
    }

    /* Bento Cards Print Adjustments */
    .bento-card {
      background-color: #0f172a !important;
      border: 1px solid rgba(255, 255, 255, 0.15) !important;
      break-inside: avoid !important;
      page-break-inside: avoid !important;
      box-shadow: none !important;
    }

    /* Prevent breaking inside experience items */
    section, .relative.pl-5 {
      break-inside: avoid !important;
      page-break-inside: avoid !important;
    }
  }
</style>
