---
import AppLayout from '../../layouts/AppLayout.astro';
import getCV, { type Locale } from '../../data/cv';

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: 'fr' } },
    { params: { lang: 'fr' }, props: { lang: 'fr' } },
    { params: { lang: 'en' }, props: { lang: 'en' } },
  ];
}

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const cv = getCV(lang);
---

<AppLayout title={cv.title} cssClass="bg-[#0D0E11] text-[#F2F4F8]">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <!-- ACTION BAR (HIDDEN IN PRINT) -->
  <div class="actions-bar print:hidden">
    <a href="/" class="back-link">
      {lang === 'fr' ? '← RETOUR AU SITE' : '← BACK TO WEBSITE'}
    </a>

    <div class="right-actions">
      <div class="lang-switcher">
        <a href="/cv/fr" class:list={['lang-btn', { active: lang === 'fr' }]}>FR</a>
        <span class="divider">|</span>
        <a href="/cv/en" class:list={['lang-btn', { active: lang === 'en' }]}>EN</a>
      </div>

      <button onclick="window.print()" class="btn-print">
        {lang === 'fr' ? 'IMPRIMER / PDF (DARK A4)' : 'PRINT / PDF (DARK A4)'}
      </button>
    </div>
  </div>

  <main class="eos-viewport">

    <!-- 0x01. SYSTEM HEADER -->
    <header class="sys-header">
      <div class="node-identity">
        <div class="status-pulse"></div>
        <span>{cv.identity.name}</span>
      </div>
      <div class="node-status">
        <span>EOS_RUNTIME: ONLINE (v1.0.0)</span>
      </div>
      <div class="node-meta">
        <span>LOC: {cv.location}</span>
      </div>
    </header>

    <!-- 0x02. LANDMARK / IDENTITY MANIFESTO -->
    <section class="eos-row">
      <div class="eos-module col-8">
        <div class="module-tag">
          <span>MODULE_01 // ARCHITECTURAL INTENT</span>
          <span>SYS_REF: 0x00A1</span>
        </div>
        <h1 class="landmark-title">{cv.subtitle}</h1>
        <p class="landmark-subtitle">
          "{cv.tagline}"
        </p>
      </div>

      <div class="eos-module col-4">
        <div class="module-tag">
          <span>MODULE_02 // CAPACITY</span>
          <span>METRICS</span>
        </div>
        <div class="metrics-stack">
          <div>
            <div class="metric-value">10+ YEARS</div>
            <div class="metric-label">Production Architecture</div>
          </div>
          <div>
            <div class="metric-value">VLANG / PHP</div>
            <div class="metric-label">Language Design & Engines</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 0x03. EXECUTIVE PROFILE SUMMARY -->
    <section class="eos-row">
      <div class="eos-module col-12">
        <div class="module-tag">
          <span>MODULE_03 // SYSTEM OVERVIEW</span>
          <span>SUMMARY</span>
        </div>
        <div class="system-prose" set:html={cv.summary} />
      </div>
    </section>

    <!-- 0x04. CORE CAPABILITIES (BENTO GRID) -->
    <section class="eos-row">
      <div class="eos-module col-12">
        <div class="module-tag">
          <span>MODULE_04 // CAPABILITIES & METHODOLOGY</span>
          <span>SPECS</span>
        </div>
        <div class="capabilities-grid">
          {cv.capabilities.map((cap) => (
            <div class="cap-card">
              <div class="cap-title">{cap.title}</div>
              <p class="cap-desc">{cap.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 0x05. PROFESSIONAL EXPERIENCES -->
    <section class="eos-row">
      <div class="eos-module col-12">
        <div class="module-tag">
          <span>MODULE_05 // EXPERIENCES & SYSTEM IMPACT</span>
          <span>TIMELINE</span>
        </div>
        
        <div class="experience-stack">
          {cv.experiences.map((exp) => (
            <div class="exp-item">
              <div class="exp-header">
                <span class="exp-role">{exp.role} — <span class="exp-company">{exp.company}</span></span>
                <span class="exp-date">{exp.period}</span>
              </div>
              {exp.subtitle && <div class="exp-subtitle">{exp.subtitle}</div>}
              <ul class="impact-list">
                {exp.impacts.map((impact) => (
                  <li set:html={impact} />
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 0x06. ECOSYSTEM & EDUCATION -->
    <section class="eos-row">
      <div class="eos-module col-7">
        <div class="module-tag">
          <span>MODULE_06 // TECHNICAL ECOSYSTEM</span>
          <span>STACK</span>
        </div>
        <div class="eco-stack">
          {cv.ecosystem.map((group) => (
            <div class="eco-group">
              <span class="eco-label">{cv.categories[group.categoryId as keyof typeof cv.categories]}:</span>
              <div class="tags-container">
                {group.skills.map((skill) => (
                  <span class="tag">{skill}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="eos-module col-5">
        <div class="module-tag">
          <span>MODULE_07 // ACADEMIC & LANGUAGES</span>
          <span>CREDENTIALS</span>
        </div>
        <div class="edu-stack">
          {cv.education.map((edu) => (
            <div class="edu-item">
              <div class="edu-deg">{edu.degree}</div>
              {edu.institution && <div class="edu-inst">{edu.institution}</div>}
              <div class="edu-date">{edu.period}</div>
            </div>
          ))}
          <div class="lang-box">
            <span class="eco-label">{lang === 'fr' ? 'LANGUES :' : 'LANGUAGES:'}</span>
            <span class="lang-text">{cv.languages}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER CONTACT -->
    <footer class="sys-footer col-12">
      <div><span>EMAIL:</span> <a href={`mailto:${cv.contact.email}`}>{cv.contact.email}</a></div>
      <div><span>WEB:</span> <a href={cv.contact.webUrl}>{cv.contact.web}</a></div>
      <div><span>GITHUB:</span> <a href={cv.contact.githubUrl}>{cv.contact.github}</a></div>
      <div><span>LINKEDIN:</span> <a href={cv.contact.linkedinUrl}>{cv.contact.linkedin}</a></div>
    </footer>

  </main>
</AppLayout>

<style>
  /* ==========================================================================
     DESIGN TOKENS & SYSTEM VARIABLES
     ========================================================================== */
  :root {
    --surface-canvas: #0D0E11;
    --surface-module: #13151A;
    --border-grid: rgba(255, 255, 255, 0.08);
    --border-grid-strong: rgba(255, 255, 255, 0.22);
    
    --text-primary: #F2F4F8;
    --text-secondary: #9DA4B2;
    --text-tertiary: #525966;
    
    --accent-system: #00FF66;
    --accent-light: #38BDF8;
    
    --font-mono: 'Fira Code', monospace;
    --font-sans: 'Inter', sans-serif;

    /* Spatial Unit Multiples (Compact Grid 1U = 3.5px) */
    --u1: 3.5px;
    --u2: 7px;
    --u3: 10.5px;
    --u4: 14px;
    --u6: 21px;
    --u8: 28px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background-color: var(--surface-canvas);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  /* Structural Grid Background */
  body::before {
    content: "";
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 100vh;
    background-image: 
      linear-gradient(to right, var(--border-grid) 1px, transparent 1px),
      linear-gradient(to bottom, var(--border-grid) 1px, transparent 1px);
    background-size: var(--u8) var(--u8);
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  .actions-bar {
    max-width: 1000px;
    margin: 0 auto;
    padding: var(--u4) var(--u4) 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 10;
  }

  .back-link { font-family: var(--font-mono); font-size: 11px; color: var(--text-secondary); text-decoration: none; }
  .back-link:hover { color: var(--accent-light); }

  .right-actions { display: flex; gap: var(--u4); align-items: center; }

  .lang-switcher {
    display: flex; gap: 6px; background: var(--surface-module);
    border: 1px solid var(--border-grid-strong); padding: 4px 10px; border-radius: 4px;
    font-family: var(--font-mono); font-size: 11px;
  }
  .lang-btn { color: var(--text-tertiary); text-decoration: none; }
  .lang-btn.active { color: var(--accent-light); font-weight: 700; }
  .divider { color: var(--border-grid-strong); }

  .btn-print {
    background: rgba(0, 255, 102, 0.1); border: 1px solid var(--accent-system);
    color: var(--accent-system); font-family: var(--font-mono); font-size: 11px;
    padding: 6px 14px; cursor: pointer; border-radius: 4px; font-weight: 600;
    transition: all 0.2s;
  }
  .btn-print:hover { background: rgba(0, 255, 102, 0.2); }

  /* CONTAINER & GRID */
  .eos-viewport {
    position: relative;
    z-index: 1;
    max-width: 1000px;
    margin: 0 auto;
    padding: var(--u6);
    display: flex;
    flex-direction: column;
    gap: var(--u4);
  }

  .sys-header {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    border-bottom: 1px solid var(--border-grid-strong);
    padding-bottom: var(--u2);
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--text-tertiary);
  }
  .node-identity { grid-column: span 4; color: var(--text-primary); font-weight: 700; display: flex; align-items: center; gap: var(--u2); }
  .node-status { grid-column: span 4; display: flex; align-items: center; gap: var(--u2); }
  .node-meta { grid-column: span 4; text-align: right; }
  .status-pulse { width: 6px; height: 6px; background: var(--accent-system); border-radius: 50%; box-shadow: 0 0 6px var(--accent-system); }

  .eos-row { display: grid; grid-template-columns: repeat(12, 1fr); gap: var(--u4); }

  .eos-module {
    background: var(--surface-module);
    border: 1px solid var(--border-grid);
    padding: var(--u4);
    position: relative;
  }
  .eos-module::before {
    content: "+"; position: absolute; top: -6px; left: -4px;
    font-family: var(--font-mono); font-size: 9px; color: var(--text-tertiary);
  }

  .module-tag {
    font-family: var(--font-mono); font-size: 9.5px; color: var(--text-tertiary);
    text-transform: uppercase; margin-bottom: var(--u2); display: flex; justify-content: space-between;
  }

  .landmark-title { font-size: 20px; font-weight: 600; color: var(--text-primary); margin-bottom: var(--u2); line-height: 1.25; }
  .landmark-subtitle { font-family: var(--font-mono); font-size: 11.5px; color: var(--text-secondary); font-style: italic; }

  .metrics-stack { display: flex; flex-direction: column; gap: var(--u3); justify-content: center; height: 100%; }
  .metric-value { font-family: var(--font-mono); font-size: 18px; font-weight: 700; color: var(--accent-light); }
  .metric-label { font-size: 10.5px; color: var(--text-secondary); text-transform: uppercase; }

  .system-prose { font-size: 12px; color: var(--text-secondary); line-height: 1.5; }
  .system-prose :global(strong) { color: var(--text-primary); }

  /* CAPABILITIES GRID */
  .capabilities-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--u3); }
  .cap-card { background: rgba(0,0,0,0.3); border: 1px solid var(--border-grid); padding: var(--u2) var(--u3); }
  .cap-title { font-family: var(--font-mono); font-size: 11px; font-weight: 700; color: var(--accent-light); margin-bottom: 2px; }
  .cap-desc { font-size: 11px; color: var(--text-secondary); line-height: 1.35; }

  /* EXPERIENCES */
  .experience-stack { display: flex; flex-direction: column; gap: var(--u3); }
  .exp-item { border-left: 2px solid var(--border-grid-strong); padding-left: var(--u3); }
  .exp-header { display: flex; justify-content: space-between; align-items: baseline; }
  .exp-role { font-size: 13px; font-weight: 700; color: var(--text-primary); }
  .exp-company { color: var(--accent-light); font-family: var(--font-mono); font-size: 11.5px; }
  .exp-date { font-family: var(--font-mono); font-size: 10.5px; color: var(--text-tertiary); }
  .exp-subtitle { font-family: var(--font-mono); font-size: 10.5px; color: var(--text-secondary); font-style: italic; margin-bottom: 4px; }

  .impact-list { margin-left: 14px; color: var(--text-secondary); }
  .impact-list li { font-size: 11.5px; margin-bottom: 2px; line-height: 1.4; }
  .impact-list li :global(strong) { color: var(--text-primary); }

  /* ECOSYSTEM & EDUCATION */
  .eco-stack { display: flex; flex-direction: column; gap: var(--u2); }
  .eco-group { font-size: 11px; }
  .eco-label { font-family: var(--font-mono); color: var(--text-primary); display: block; margin-bottom: 3px; font-size: 10.5px; font-weight: 700; }
  .tags-container { display: flex; flex-wrap: wrap; gap: 4px; }
  .tag { background: rgba(255,255,255,0.05); border: 1px solid var(--border-grid); padding: 2px 6px; font-family: var(--font-mono); font-size: 9.5px; color: var(--text-secondary); }

  .edu-stack { display: flex; flex-direction: column; gap: var(--u2); }
  .edu-deg { font-weight: 700; color: var(--text-primary); font-size: 11.5px; }
  .edu-inst { color: var(--text-secondary); font-size: 11px; }
  .edu-date { font-family: var(--font-mono); font-size: 10px; color: var(--text-tertiary); }
  .lang-box { border-top: 1px solid var(--border-grid); padding-top: var(--u2); margin-top: var(--u2); }
  .lang-text { font-size: 11px; color: var(--accent-light); }

  .sys-footer {
    border-top: 1px solid var(--border-grid-strong); padding-top: var(--u3);
    font-family: var(--font-mono); font-size: 10px; color: var(--text-tertiary);
    display: flex; justify-content: space-between;
  }
  .sys-footer a { color: var(--accent-light); text-decoration: none; }

  /* Column Utilities */
  .col-12 { grid-column: span 12; }
  .col-8 { grid-column: span 8; }
  .col-7 { grid-column: span 7; }
  .col-5 { grid-column: span 5; }
  .col-4 { grid-column: span 4; }

  /* ==========================================================================
     STRICT A4 PRINT SYSTEM (DARK MODE PRESERVED - EXACTLY 2 PAGES)
     ========================================================================== */
  @media print {
    @page {
      size: A4 portrait;
      margin: 8mm 6mm;
    }

    * {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      color-adjust: exact !important;
    }

    html, body {
      background-color: #0D0E11 !important;
      color: #F2F4F8 !important;
      font-size: 11px !important;
    }

    body::before { display: none !important; }

    .eos-viewport {
      padding: 0 !important;
      max-width: 100% !important;
      gap: 10px !important;
    }

    .eos-module {
      background: #13151A !important;
      border: 1px solid rgba(255, 255, 255, 0.15) !important;
      padding: 10px 12px !important;
      break-inside: avoid !important;
      page-break-inside: avoid !important;
    }

    .landmark-title { font-size: 16px !important; margin-bottom: 4px !important; }
    .landmark-subtitle { font-size: 10.5px !important; }
    .metric-value { font-size: 15px !important; }

    .capabilities-grid { gap: 6px !important; }
    .cap-card { padding: 6px 8px !important; }

    .experience-stack { gap: 8px !important; }
    .exp-item { break-inside: avoid !important; page-break-inside: avoid !important; }

    .impact-list li { font-size: 10px !important; margin-bottom: 1px !important; }

    /* Force clean page break after major sections if needed */
    .eos-row { break-inside: avoid !important; page-break-inside: avoid !important; }
  }
</style>
