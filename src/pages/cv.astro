---
import AppLayout from '../layouts/AppLayout.astro';
---
<style>
:root {
  --bg: #0a0a0a;
  --card: #121212;
  --text: #e5e5e5;
  --muted: #a3a3a3;
  --accent: #7c3aed;
  --accent-light: #c084fc;
  --border: #262626;
  --font: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  --mono: "JetBrains Mono", SFMono-Regular, Consolas, monospace;
}

* { box-sizing: border-box; }

body {
  margin: 0;
  padding: 32px 16px;
  background: var(--bg);
  color: var(--text);
  font-family: var(--font);
  line-height: 1.5;
  font-size: 14px;
}

a { color: inherit; text-decoration: none; }
a:hover { color: var(--accent-light); }

.container, .actions { max-width: 850px; margin: auto; }

.actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.back-link { color: var(--muted); font-size: 14px; }
.back-link:hover { color: var(--text); }

button {
  background: var(--accent);
  color: white;
  border: 0;
  padding: 10px 18px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: opacity 0.2s;
}
button:hover { opacity: 0.9; }

.cv {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 48px;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
}

header {
  border-bottom: 2px solid var(--border);
  padding-bottom: 24px;
  margin-bottom: 24px;
}

h1 { font-size: 34px; margin: 0; font-weight: 800; color: #ffffff; }

.subtitle { color: var(--accent-light); font-weight: 700; font-size: 17px; margin-top: 4px; }

.contact {
  display: flex;
  flex-wrap: wrap;
  gap: 12px 24px;
  color: var(--muted);
  margin-top: 16px;
  font-size: 13.5px;
}

section { margin-bottom: 28px; }

h2 {
  color: var(--accent-light);
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: .08em;
  border-bottom: 1px solid var(--border);
  padding-bottom: 6px;
  margin-bottom: 16px;
}

p, li { color: var(--muted); }
ul { margin: 8px 0; padding-left: 20px; }
li { margin-bottom: 4px; }

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

.item { margin-bottom: 20px; break-inside: avoid; }
.item-title { font-weight: 700; color: white; font-size: 15px; }
.company { color: var(--text); font-weight: 600; }
.date { float: right; color: var(--muted); font-family: var(--mono); font-size: 13px; font-weight: normal; }

.tag {
  display: inline-block;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border);
  padding: 3px 9px;
  border-radius: 999px;
  margin: 2px;
  color: #ddd;
  font-size: 12px;
  font-family: var(--mono);
}

@media(max-width: 700px) {
  .cv { padding: 24px; }
  .grid { grid-template-columns: 1fr; }
  h1 { font-size: 28px; }
  .date { float: none; display: block; margin-top: 2px; }
}

/* =========================================================
   STRICT ATS & PRINT STYLES
   ========================================================= */
@media print {
  @page { size: A4; margin: 12mm 15mm; }
  body { background: white !important; color: black !important; padding: 0 !important; font-size: 10pt !important; }
  .actions { display: none !important; }
  .cv { border: 0 !important; background: white !important; padding: 0 !important; box-shadow: none !important; }
  h1, .item-title, .company { color: black !important; }
  .subtitle { color: #333 !important; }
  h2 { color: black !important; border-bottom: 1pt solid black !important; }
  p, li, .contact, .date { color: #222 !important; }
  .tag { border: 1px solid #ccc !important; background: #f5f5f5 !important; color: black !important; }
  .item { break-inside: avoid !important; }
}
</style>
