---
import '../styles/app.css';
import { app } from '../config';
import ClientRouter from 'astro/components/ClientRouter.astro';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
	animate?: 'fade' | 'initial' | 'slide' | 'none';
	transitions?: 'animate' | 'swap' | 'none';
  cssClass?: string | undefined;
  data?: string | undefined;
  rootId ?: string | undefined;
  bodyId ?: string | undefined;
}

const {
	title,
  description = 'The personal website of Sigui Kessé Emmanuel',
  animate = 'fade',
	transitions = 'animate',
  rootId = 'root',
  bodyId = 'app',
} = Astro.props;

let {
  cssClass = 'antialiased noise bg-[#fef9f2] dark:bg-[#040711] bg-gradient-to-b from-[#070617] via-[#070922] to-[#0b0720] min-h-screen w-full font-sans text-slate-100 relative overflow-x-hidden flex flex-col selection:bg-ske-500/60 selection:text-white',
  data,
} = Astro.props;

data = data ? `{ transitioning: false, ' ${data.replace('{', '')}` : '{ transitioning: false }';
---

<!DOCTYPE html>
<html
  lang="en"
  transition:animate={animate}
  class="scroll-smooth no-scrollbar h-full w-full select-none touch-manipulation"
  id={ rootId }
  >
	<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover,shrink-to-fit=no"/>
    <meta name="description" property="og:description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{(process.env.APP_NAME || app.title) + (title ? ` - ${title}` : '')}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <ClientRouter fallback={transitions} transition:persist />

    <link rel="alternate" type="application/rss+xml" title="Flux RSS de SIGUI Kessé Emmanuel" href="/rss.xml" />

    <link rel="manifest" href="/manifest.json" />
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="SIGUICI">

    <meta name="author" content="Emmanuel SIGUI" />
    <link rel="canonical" href="https://siguici.github.io/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Emmanuel Kessé SIGUI — Software Architect & Platform Engineer" />
    <meta
        property="og:description"
        content="Building the future of the open web through open-source software, developer tools, and high-performance backend platforms."
    />
    <meta property="og:url" content="https://siguici.github.io/" />
    <meta property="og:image" content="/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Emmanuel Kessé SIGUI — Software Architect" />
    <meta
        name="twitter:description"
        content="Senior Software Architect & Platform Engineer designing backend systems and developer tools."
    />
    <meta name="twitter:image" content="/og-image.png" />

		<script>
			// Add “loaded” class once the document has completely loaded.
			addEventListener('load', () => document.documentElement.classList.add('loaded'));
		</script>

    <script is:inline type="ts" src="../assets/preloader.ts" defer></script>

    <script is:inline>
      // This code is inlined in the head to make dark mode instant & blocking.
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      const isDark = getThemePreference() === 'dark';
      document.documentElement.classList[isDark ? 'add' : 'remove']('theme-dark');

      if (typeof localStorage !== 'undefined') {
        // Watch the document element and persist user preference when it changes.
        const observer = new MutationObserver(() => {
          const isDark = document.documentElement.classList.contains('theme-dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      }
    </script>
	</head>
  <body x-data={ data }
    id={bodyId}
    :class="{ 'transitioning': transitioning }"
    class={cssClass}
    >
    <div id="preloader"></div>
    <slot />
  </body>
</html>
