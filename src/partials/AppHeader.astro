<header class="sticky top-0 z-50 w-full border-b border-black/5 bg-white/80 backdrop-blur-md dark:border-white/5 dark:bg-[#0d1117]/80">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">

    <!-- Brand / Logo -->
    <a href="#" class="font-mono flex items-center gap-2 font-bold tracking-tight text-xl">
      <span class="text-primary">&lt;</span>
      <span>siguici</span>
      <span class="text-primary">/&gt;</span>
    </a>

    <!-- Main Menu (Desktop) -->
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium opacity-90">
      <a href="#vision" class="hover:text-primary transition-colors">Vision</a>
      <a href="#projects" class="hover:text-primary transition-colors">Projects</a>
      <a href="#background" class="hover:text-primary transition-colors">Background</a>
      <a href="#courses" class="hover:text-primary transition-colors">Courses</a>
      <a href="#contact" class="hover:text-primary transition-colors">Contact</a>
      <a href="https://sikessem.com" target="_blank" rel="noopener noreferrer" class="text-xs font-mono px-2 py-1 rounded bg-black/5 dark:bg-white/5 hover:bg-primary/10 hover:text-primary transition-all">Sikessem ↗</a>
    </nav>

    <!-- Toolbar (Search, RSS, Theme) -->
    <div class="flex items-center gap-3 sm:gap-4">

      <!-- Minimal Search Bar -->
      <div class="relative hidden sm:block">
        <input
          type="text"
          placeholder="Search..."
          class="w-48 rounded-full bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 px-4 py-1.5 text-xs focus:outline-none focus:border-primary focus:w-64 transition-all"
        />
        <span class="absolute right-3 top-2 text-[10px] opacity-40 font-mono">⌘K</span>
      </div>

      <!-- RSS Button -->
      <a href="/feed.xml" title="RSS Feed" aria-label="RSS Feed" class="rss-link font-black p-2 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
        <span class="sr-only">RSS Feed</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          class="size-4"
          style="fill: currentColor;transform: ;msFilter:;"
          ><path d="M19 20.001C19 11.729 12.271 5 4 5v2c7.168 0 13 5.832 13 13.001h2z"></path><path
            d="M12 20.001h2C14 14.486 9.514 10 4 10v2c4.411 0 8 3.589 8 8.001z"></path><circle cx="6" cy="18" r="2"
          ></circle>
        </svg>
      </a>

      <!-- Theme Switcher -->
      <div class="relative inline-flex rounded-full bg-black/5 dark:bg-white/5 p-1 border border-black/10 dark:border-white/10" id="theme-selector">
        <button type="button" data-theme-btn="light" class="rounded-full p-1.5 hover:text-primary transition-colors" title="Light Mode" aria-label="Light Mode">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 5a7 7 0 100 14 7 7 0 000-14z"/></svg>
        </button>
        <button type="button" data-theme-btn="dark" class="rounded-full p-1.5 transition-colors" title="Dark Mode" aria-label="Dark Mode">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </button>
        <button type="button" data-theme-btn="system" class="rounded-full p-1.5 hover:text-primary transition-colors" title="System Mode" aria-label="System Mode">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </button>
      </div>

    </div>
  </div>
</header>
