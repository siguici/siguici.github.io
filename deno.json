{
  "license": "AGPL-3.0-or-later",
  "nodeModulesDir": "auto",
  "lock": true,
  "unstable": ["kv"],
  "allowScripts": ["npm:esbuild@0.27.7", "npm:sharp@0.34.5"],
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ]
  },
  "test": { "include": ["tests/"], "exclude": ["dist/"] },
  "imports": {
    "~/": "./",
    "@/": "./src/"
  },
  "exclude": [
    "**/dist/**",
    "**/.astro/**",
    "**/pagefind/**"
  ],
  "lint": {
    "rules": { "tags": ["recommended"] }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "tasks": {
    "build": "deno run -A npm:astro build",
    "check": "deno run -A npm:astro check && deno fmt --check && deno check --sloppy-imports && deno lint",
    "deploy": "deno deploy app --org=sigui --app=emmanuel --prod",
    "dev": "deno run -A npm:astro dev",
    "fix": "./run sync && deno lint --fix && deno fmt",
    "preview": "deno run -A npm:astro preview",
    "prod": "./run check && ./run build",
    "serve": "deno run -A dist/server/entry.mjs",
    "sync": "deno run -A npm:astro sync",
    "upgrade": "deno run -A npm:@astrojs/upgrade"
  }
}
